# Flask
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-me-in-production

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/predictcup

# Redis (排行榜快取 / 排程器分散式鎖)
REDIS_URL=redis://localhost:6379/0

# CORS 允許來源（逗號分隔）。dev 可留 *；正式環境必設前端網域，否則拒絕啟動
CORS_ORIGINS=*

# --- Auth / SSO ---
JWT_SECRET=change-me-too
JWT_EXPIRES_HOURS=72
ALLOW_DEV_LOGIN=true          # 正式環境設 false
# GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com

# 管理者名單（登入時比對 email 或 username，命中即可進後台）
# 正式環境：填你的管理者 Google email（逗號分隔可多人）
ADMIN_EMAILS=
ADMIN_USERNAMES=Mike

# --- AI 微服務 (缺省走啟發式) ---
# ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-opus-4-8

# --- 第三方賽事 API (API-Football，匯入世界盃賽程 + 同步賽果) ---
# SPORTS_API_KEY=your-api-football-key
# SPORTS_API_BASE=https://v3.football.api-sports.io
SPORTS_LEAGUE_ID=1            # FIFA World Cup
SPORTS_SEASON=2026

# --- 排程器 (Cron 自動結算 / 賽果同步) ---
SCHEDULER_ENABLED=false
SETTLE_INTERVAL_MINUTES=5
RESULT_SYNC_INTERVAL_MINUTES=10
